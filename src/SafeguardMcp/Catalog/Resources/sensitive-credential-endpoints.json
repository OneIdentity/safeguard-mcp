[
  {
    "kind": "access-request-password",
    "requires": ["accessRequestId"],
    "endpoints": [
      { "method": "POST", "pathPattern": "^/v4/AccessRequests/\\d+/CheckOutPassword$", "arg": "accessRequestId" }
    ]
  },
  {
    "kind": "access-request-ssh-key",
    "requires": ["accessRequestId"],
    "endpoints": [
      { "method": "POST", "pathPattern": "^/v4/AccessRequests/\\d+/CheckOutSshKey$", "arg": "accessRequestId" }
    ]
  },
  {
    "kind": "access-request-api-key",
    "requires": ["accessRequestId"],
    "endpoints": [
      { "method": "POST", "pathPattern": "^/v4/AccessRequests/\\d+/CheckOutApiKeys$", "arg": "accessRequestId" }
    ]
  },
  {
    "kind": "access-request-totp",
    "requires": ["accessRequestId"],
    "endpoints": [
      { "method": "POST", "pathPattern": "^/v4/AccessRequests/\\d+/CheckOutTotp$", "arg": "accessRequestId" }
    ]
  },
  {
    "kind": "access-request-file",
    "requires": ["accessRequestId"],
    "endpoints": [
      { "method": "POST", "pathPattern": "^/v4/AccessRequests/\\d+/CheckOutFile$", "arg": "accessRequestId" }
    ]
  },
  {
    "kind": "personal-account-password",
    "requires": ["accountId"],
    "endpoints": [
      { "method": "GET", "pathPattern": "^/v4/Me/EnterpriseAccounts/\\d+/Password$", "arg": "accountId" }
    ]
  },
  {
    "kind": "personal-account-password-history",
    "requires": ["accountId"],
    "endpoints": [
      { "method": "GET", "pathPattern": "^/v4/Me/EnterpriseAccounts/\\d+/Passwords$", "arg": "accountId" }
    ]
  },
  {
    "kind": "personal-account-totp",
    "requires": ["accountId"],
    "endpoints": [
      { "method": "GET", "pathPattern": "^/v4/Me/EnterpriseAccounts/\\d+/TotpAuthenticator/Values$", "arg": "accountId" }
    ]
  },
  {
    "kind": "generated-password",
    "requires": [],
    "endpoints": [
      { "method": "POST", "pathPattern": "^/v4/Me/EnterpriseAccounts/GeneratePassword$" }
    ]
  },
  {
    "kind": "asset-account-api-secret-history",
    "requires": ["accountId", "apiKeyId"],
    "endpoints": [
      { "method": "GET", "pathPattern": "^/v4/AssetAccounts/\\d+/ApiKeys/\\d+/ClientSecrets$", "args": ["accountId", "apiKeyId"] }
    ]
  }
]
