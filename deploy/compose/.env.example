# Copy this file to `.env` (in this same directory) and edit before
# running `docker compose up`.
#
# None of these values are secret. The bridge is a public PKCE client
# at rSTS — there is no client secret. Safeguard tokens are never
# persisted by safeguard-mcp.

# ---------- Required ----------

# Public DNS name / hostname of the Safeguard appliance.
SAFEGUARD_HOST=safeguard.example.com

# ---------- OAuth bridge (optional) ----------
#
# The OAuth bridge is on by default. It infers its public URL from
# each incoming request (Scheme + Host + PathBase, where Scheme/Host
# honor X-Forwarded-Proto / X-Forwarded-Host from a trusted ingress).
#
# Set BRIDGE_DISABLED=true to disable the bridge entirely (relay only).
# In that mode the container only serves /mcp and /healthz; MCP
# clients must authenticate by passing a bearer token they obtained
# out-of-band.
#
# MCP_PUBLIC_URL / RSTS_CLIENT_ID are optional pinning overrides.
# Set them only when:
#   * The rSTS RelyingPartyApplication.Realm was registered under a
#     name that differs from the user-facing hostname.
#   * You want well-known metadata to advertise a fixed canonical
#     URL even when requests arrive on alternate hostnames.
# When set, MCP_PUBLIC_URL is published verbatim in /.well-known/*.
# RSTS_CLIENT_ID must be an absolute URI; rSTS asserts this. If only
# MCP_PUBLIC_URL is set, RSTS_CLIENT_ID defaults to it.
#
# MCP_PUBLIC_URL=https://mcp.example.com
# RSTS_CLIENT_ID=https://mcp.example.com
# BRIDGE_DISABLED=true

# Forwarded-headers trust (advanced). Set only when your reverse
# proxy / ingress IP falls outside the default trust list (loopback +
# RFC1918). Comma-separated CIDRs; IPv4 and IPv6 supported.
# BRIDGE_TRUSTED_PROXIES=100.64.0.0/10,2001:db8::/32

# Lifetime of an unredeemed bridge auth code, seconds (1..300).
BRIDGE_AUTH_CODE_TTL_SECONDS=60

# ---------- Lab/dev only ----------

# Set to "true" only if your appliance presents a certificate the
# container cannot verify. Leave "false" in production.
SAFEGUARD_IGNORE_SSL=false
